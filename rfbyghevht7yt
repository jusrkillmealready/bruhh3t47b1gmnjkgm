print("[Yoxi Loader] --- СТАРТ ЛОАДЕРА ---")

local _loadstring = loadstring or load
if type(_loadstring) ~= "function" then
    warn("[Yoxi Loader] ФАТАЛЬНО: Экзекутор не поддерживает loadstring.")
    return
end

print("[Yoxi Loader] Шаг 1: Подготовка окружения")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local TextService = game:GetService("TextService")
local Lighting = game:GetService("Lighting")
local UserInputService = game:GetService("UserInputService")

local _spawn = (type(task) == "table" and type(task.spawn) == "function" and task.spawn) or spawn
local _wait = (type(task) == "table" and type(task.wait) == "function" and task.wait) or wait
local _delay = (type(task) == "table" and type(task.delay) == "function" and task.delay) or delay

print("[Yoxi Loader] Шаг 2: Поиск GUI")
local function GetSafeGuiParent()
    if type(gethui) == "function" then
        return gethui()
    end
    if type(CoreGui) == "userdata" then
        return CoreGui
    end
    return Players.LocalPlayer:WaitForChild("PlayerGui")
end

local targetParent = GetSafeGuiParent()
if not targetParent then warn("[Yoxi Loader] Нет места для создания UI!") end

print("[Yoxi Loader] Шаг 3: Создание UI")
-- Облегченный UI, чтобы исключить баги мобильного рендера
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "YOXI_Loader"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global

if type(syn) == "table" and type(syn.protect_gui) == "function" then
    syn.protect_gui(screenGui)
end
screenGui.Parent = targetParent

local background = Instance.new("Frame")
background.Size = UDim2.new(1, 0, 1, 0)
background.BackgroundColor3 = Color3.fromRGB(5, 2, 2)
background.Parent = screenGui

local textLabel = Instance.new("TextLabel")
textLabel.Size = UDim2.new(1, 0, 1, 0)
textLabel.BackgroundTransparency = 1
textLabel.Text = "YOXI HUB\nLoading..."
textLabel.TextColor3 = Color3.fromRGB(255, 15, 15)
textLabel.TextSize = 40
textLabel.Font = Enum.Font.GothamBlack
textLabel.Parent = background

local function HideUI()
    print("[Yoxi Loader] Удаление UI...")
    pcall(function() screenGui:Destroy() end)
end

print("[Yoxi Loader] Шаг 4: Сбор данных")
local placeId = tostring(game.PlaceId)
local gameId = tostring(game.GameId)
local API_URL = "https://yoxi-hub.fun/api/loader?placeId=" .. placeId .. "&t=" .. tostring(os.time())

_spawn(function()
    print("[Yoxi Loader] Шаг 5: HTTP Запрос к серверу...")
    local success, response = pcall(function()
        return game:HttpGet(API_URL)
    end)

    if not success then
        warn("[Yoxi Loader] Ошибка сети (game:HttpGet): " .. tostring(response))
        textLabel.Text = "Network Error"
        _delay(3, HideUI)
        return
    end

    if type(response) ~= "string" or response == "" or response:find("<html") then
        warn("[Yoxi Loader] Сервер вернул мусор или капчу Cloudflare!")
        textLabel.Text = "Cloudflare Blocked"
        _delay(3, HideUI)
        return
    end

    print("[Yoxi Loader] Шаг 6: Компиляция кода...")
    local fn, compileErr = _loadstring(response)
    
    if not fn then
        warn("[Yoxi Loader] Ошибка компиляции кода (Синтаксис): " .. tostring(compileErr))
        textLabel.Text = "Compile Error"
        _delay(3, HideUI)
        return
    end

    print("[Yoxi Loader] Шаг 7: Запуск основного скрипта (ХАБА)...")
    HideUI() -- Скрываем лоадер перед запуском
    
    local execSuccess, execErr = pcall(fn)
    
    if not execSuccess then
        warn("\n\n[YOXI HUB CRASHED]\nОшибка произошла ВНУТРИ самого хаба (uniyo.txt), а не в лоадере!\nТекст ошибки: " .. tostring(execErr) .. "\n\n")
    else
        print("[Yoxi Loader] Хаб успешно загружен!")
    end
end)
