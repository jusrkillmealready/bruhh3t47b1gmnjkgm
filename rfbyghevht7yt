-- Функция для безопасного получения GUI-контейнера
local function GetSafeGuiParent()
    local success, hui = _pcall(function() return gethui() end)
    if success and hui then return hui end
    local success2, core = _pcall(function() return CoreGui end)
    if success2 and core then return core end
    return Players.LocalPlayer:WaitForChild("PlayerGui", 10)
end

local function getIds()
    local timeout = 10 -- Максимальное время ожидания 10 секунд
    local elapsed = 0
    while game.PlaceId == 0 and elapsed < timeout do 
        _wait(0.5) 
        elapsed = elapsed + 0.5
    end
    return _tostring(game.PlaceId), _tostring(game.GameId)
end

local function normalizeResponse(response)
    if _type(response) ~= "string" then return nil end
    response = response:gsub("^\239\187\191", ""):gsub("^%s+", ""):gsub("%s+$", "")

    if response == "" then return nil end

    local lower = response:lower()
    -- Если Cloudflare выдал HTML (капчу/заглушку)
    if lower:find("<html") or lower:find("<!doctype") then
        warn("[Yoxi Hub] Ошибка: Cloudflare заблокировал запрос (выдана HTML страница).")
        return nil
    end

    if lower == "нет" or lower:find("^error") or lower:find("^forbidden") or lower:find("^blocked") then
        warn("[Yoxi Hub] Ошибка доступа от сервера: " .. response)
        return nil
    end

    return response
end

local function ShowLoadingUI()
    local targetParent = GetSafeGuiParent()
    if not targetParent then 
        warn("[Yoxi Hub] Не удалось найти место для создания UI.")
        return function() end 
    end

    local TITLE_TEXT = "YOXI HUB"
    local LOGO_ID = "rbxassetid://80841138859899"
    local FONT = Enum.Font.GothamBlack
    local CHAR_APPEAR_DELAY = 0.06
    local BACKGROUND_FADE_IN = 1
    local BLUR_SIZE = 18

    local black = Color3.fromRGB(5, 2, 2)
    local veryDarkRed = Color3.fromRGB(40, 0, 0)
    local neonRed = Color3.fromRGB(255, 15, 15)

    -- Удаляем старые версии
    for _, c in pairs(targetParent:GetChildren()) do
        if c.Name == "YOXI_Loader" then
            _pcall(function() c:Destroy() end)
        end
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "YOXI_Loader"
    screenGui.IgnoreGuiInset = true
    screenGui.ResetOnSpawn = false
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    
    -- Защита UI от обнаружения (если поддерживает экзекутор)
    _pcall(function() syn.protect_gui(screenGui) end)
    
    screenGui.Parent = targetParent

    local background = Instance.new("Frame")
    background.Name = "Background"
    background.Size = UDim2.new(1, 0, 1, 0)
    background.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    background.BackgroundTransparency = 1
    background.BorderSizePixel = 0
    background.Parent = screenGui

    local bgGradient = Instance.new("UIGradient")
    bgGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, black),
        ColorSequenceKeypoint.new(0.5, veryDarkRed),
        ColorSequenceKeypoint.new(1, black)
    })
    bgGradient.Rotation = 90
    bgGradient.Parent = background

    local blur = Instance.new("BlurEffect")
    blur.Name = "YOXI_Loader_Blur"
    blur.Size = 0
    blur.Parent = Lighting

    local centerContainer = Instance.new("Frame")
    centerContainer.Size = UDim2.new(1, 0, 1, 0)
    centerContainer.BackgroundTransparency = 1
    centerContainer.Parent = background

    local function createParticles()
        coroutine.wrap(function()
            while background.Parent do
                local particle = Instance.new("Frame")
                local size = math.random(2, 5)
                particle.Size = UDim2.new(0, size, 0, size)
                particle.Position = UDim2.new(math.random(), 0, 1.1, 0)
                particle.BackgroundColor3 = neonRed
                particle.BackgroundTransparency = math.random(50, 80) / 100
                particle.BorderSizePixel = 0

                local corner = Instance.new("UICorner")
                corner.CornerRadius = UDim.new(1, 0)
                corner.Parent = particle
                particle.Parent = background

                local speed = math.random(3, 8)
                local targetY = math.random(10, 60) / 100

                local tween = TweenService:Create(particle, TweenInfo.new(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
                    Position = UDim2.new(particle.Position.X.Scale + math.random(-5, 5)/100, 0, targetY, 0),
                    BackgroundTransparency = 1
                })
                tween:Play()
                tween.Completed:Connect(function() particle:Destroy() end)
                _wait(math.random(1, 4) / 10)
            end
        end)()
    end

    local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1280, 720)
    local isMobile = UserInputService.TouchEnabled
    local baseTextSize = isMobile and 40 or 70
    local textSize = math.clamp(baseTextSize, 30, 130)
    local holderWidth = math.floor(vp.X * (isMobile and 0.95 or 0.7))
    local holderHeight = textSize * 1.5

    local logoY = isMobile and 0.35 or 0.38
    local textHolderY = isMobile and 0.50 or 0.55
    local subTextY = isMobile and 0.58 or 0.65

    local textHolder = Instance.new("Frame")
    textHolder.AnchorPoint = Vector2.new(0.5, 0.5)
    textHolder.Position = UDim2.new(0.5, 0, textHolderY, 0)
    textHolder.BackgroundTransparency = 1
    textHolder.Parent = centerContainer

    local logoSize = isMobile and (textSize * 1.5) or (textSize * 2.5)
    local logo = Instance.new("ImageLabel")
    logo.AnchorPoint = Vector2.new(0.5, 0.5)
    logo.Position = UDim2.new(0.5, 0, logoY, 0)
    logo.Size = UDim2.new(0, logoSize * 0.5, 0, logoSize * 0.5)
    logo.BackgroundTransparency = 1
    logo.Image = LOGO_ID
    logo.ImageTransparency = 1
    logo.ScaleType = Enum.ScaleType.Fit
    logo.Parent = centerContainer

    local subText = Instance.new("TextLabel")
    subText.AnchorPoint = Vector2.new(0.5, 0.5)
    subText.Position = UDim2.new(0.5, 0, subTextY, 0)
    subText.Size = UDim2.new(0.9, 0, 0, textSize * 0.6)
    subText.BackgroundTransparency = 1
    subText.Text = "Loading Yoxi Hub, wait some pls :3"
    subText.Font = Enum.Font.GothamMedium
    subText.TextSize = isMobile and 16 or math.clamp(textSize * 0.25, 12, 24)
    subText.TextColor3 = Color3.fromRGB(255, 255, 255)
    subText.TextTransparency = 1
    subText.TextWrapped = true
    subText.Parent = centerContainer

    local function createCharLabels(text, textSz, font, holderW, holderH)
        local charInfos = {}
        local totalW = 0
        local spacing = math.floor(textSz * 0.05)

        for i = 1, #text do
            local ch = string.sub(text, i, i)
            local bounds = TextService:GetTextSize(ch, textSz, font, Vector2.new(2000, 2000))
            local w = math.ceil(bounds.X)
            table.insert(charInfos, {char = ch, w = w})
            totalW = totalW + w
        end
        totalW = totalW + spacing * (#text - 1)

        if totalW > holderW then
            local overflow = totalW - holderW
            local reducePerGap = math.ceil(overflow / math.max(1, (#text - 1)))
            spacing = math.max(0, spacing - reducePerGap)
            totalW = 0
            for _, info in ipairs(charInfos) do totalW = totalW + info.w end
            totalW = totalW + spacing * (#text - 1)
        end

        local startX = math.floor((holderW - totalW) / 2)
        local x = startX
        textHolder.Size = UDim2.new(0, holderW, 0, holderH)
        local charLabels = {}

        for i, info in ipairs(charInfos) do
            local w = info.w
            local charContainer = Instance.new("Frame")
            charContainer.Size = UDim2.new(0, w, 1, 0)
            charContainer.Position = UDim2.new(0, x, 0, 40)
            charContainer.BackgroundTransparency = 1
            charContainer.Parent = textHolder

            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = info.char
            lbl.TextSize = textSz
            lbl.Font = font
            lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            lbl.TextTransparency = 1
            lbl.Parent = charContainer

            local g = Instance.new("UIGradient")
            g.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, neonRed),
                ColorSequenceKeypoint.new(0.5, veryDarkRed),
                ColorSequenceKeypoint.new(1, neonRed)
            })
            g.Rotation = 90
            g.Parent = lbl

            table.insert(charLabels, { container = charContainer, label = lbl, gradient = g, xFinal = x })
            x = x + w + spacing
        end
        return charLabels
    end

    local labels = createCharLabels(TITLE_TEXT, textSize, FONT, holderWidth, holderHeight)
    local isRunning = true

    TweenService:Create(background, TweenInfo.new(BACKGROUND_FADE_IN, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), { BackgroundTransparency = 0.05 }):Play()
    TweenService:Create(blur, TweenInfo.new(BACKGROUND_FADE_IN, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), { Size = BLUR_SIZE }):Play()
    createParticles()

    TweenService:Create(logo, TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, logoSize, 0, logoSize),
        ImageTransparency = 0
    }):Play()

    for i, info in ipairs(labels) do
        task.delay(i * CHAR_APPEAR_DELAY, function()
            if not isRunning then return end
            TweenService:Create(info.container, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Position = UDim2.new(0, info.xFinal, 0, 0) }):Play()
            TweenService:Create(info.label, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextTransparency = 0 }):Play()
        end)
    end

    task.delay((#labels * CHAR_APPEAR_DELAY) + 0.3, function()
        if not isRunning then return end
        TweenService:Create(subText, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextTransparency = 0.1 }):Play()

        coroutine.wrap(function()
            _wait(1)
            while isRunning and subText.Parent do
                TweenService:Create(subText, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { TextTransparency = 0.8 }):Play()
                _wait(2)
                if not isRunning then break end
                TweenService:Create(subText, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { TextTransparency = 0.1 }):Play()
                _wait(3.5)
            end
        end)()
    end)

    coroutine.wrap(function()
        local offset = -1
        while isRunning and background.Parent do
            offset = offset + 0.008
            if offset > 1 then offset = -1 end
            for _, info in ipairs(labels) do info.gradient.Offset = Vector2.new(0, offset) end
            RunService.RenderStepped:Wait()
        end
    end)()

    local function HideUI()
        isRunning = false
        _pcall(function()
            local s = Instance.new("Sound")
            s.SoundId = "rbxassetid://132067856318530"
            s.Volume = 1
            s.Parent = workspace
            s:Play()
            task.delay(5, function() _pcall(function() s:Destroy() end) end)
        end)

        TweenService:Create(logo, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), { Size = UDim2.new(0, logoSize * 0.5, 0, logoSize * 0.5), ImageTransparency = 1 }):Play()
        TweenService:Create(subText, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { TextTransparency = 1 }):Play()

        for i, info in ipairs(labels) do
            local randomX = math.random(-25, 25)
            TweenService:Create(info.container, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.In), { Position = UDim2.new(0, info.xFinal + randomX, 0, 60) }):Play()
            TweenService:Create(info.label, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { TextTransparency = 1 }):Play()
            _wait(0.02)
        end

        local hideTween = TweenService:Create(background, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { BackgroundTransparency = 1 })
        local blurTween = TweenService:Create(blur, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { Size = 0 })

        hideTween:Play()
        blurTween:Play()
        hideTween.Completed:Wait()

        _pcall(function()
            screenGui:Destroy()
            blur:Destroy()
        end)
    end

    return HideUI
end

-- Стартуем UI
print("[Yoxi Hub] Загрузка UI...")
local hideUIFunc = ShowLoadingUI()

local placeId, gameId = getIds()
local player = Players.LocalPlayer
local playerName = player and player.Name or "Unknown"

if MAINTENANCE_MODE and playerName ~= ALLOWED_TESTER then
    _wait(2)
    player:Kick("🔧 Yoxi Hub is updating!\n\nThe script is temporarily unavailable for testing.")
    return
end

local minDisplayTime = 5
local startTime = os.clock()

local function fetchScriptWithRetry(maxRetries)
    local retries = maxRetries or 3
    local baseDelay = 2

    for attempt = 1, retries do
        local requestUrl = API_URL .. "?placeId=" .. placeId .. "&gameId=" .. gameId .. "&t=" .. _tostring(os.time())
        print("[Yoxi Hub] Попытка загрузки скрипта (" .. attempt .. "/" .. retries .. ")")
        
        local success, response = _pcall(function()
            return _httpGet(game, requestUrl)
        end)

        if success and response then
            return true, response
        else
            warn("[Yoxi Hub] Ошибка сети на попытке " .. attempt .. ": " .. _tostring(response))
            if attempt < retries then _wait(baseDelay * attempt) end
        end
    end
    return false, nil
end

_spawn(function()
    _wait(2) -- Даем UI время появиться

    local success, response = fetchScriptWithRetry(3)
    local source = normalizeResponse(success and response or nil)

    if source then
        local fn, compileErr = _loadstring(source)
        if fn then
            local ok, execErr = _pcall(fn)
            if not ok then
                warn("[Yoxi Hub] Ошибка выполнения основного скрипта: " .. _tostring(execErr))
            end
        else
            warn("[Yoxi Hub] Ошибка компиляции (Cloudflare мог обрезать код): " .. _tostring(compileErr))
        end
    else
        warn("[Yoxi Hub] Не удалось получить валидный код от сервера. Проверьте F9.")
    end

    local elapsed = os.clock() - startTime
    if elapsed < minDisplayTime then
        _wait(minDisplayTime - elapsed)
    end

    hideUIFunc()
end)
